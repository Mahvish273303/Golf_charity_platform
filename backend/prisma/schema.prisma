generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MatchTier {
  JACKPOT
  TIER2
  TIER3
  NO_WIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
}

model User {
  id                     String   @id @default(uuid())
  fullName               String
  email                  String   @unique
  passwordHash           String
  role                   Role     @default(USER)
  isActive               Boolean  @default(true)
  charityId              String?
  contributionPercentage Int      @default(10)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  subscriptions Subscription[]
  scores        Score[]
  draws         Draw[]               @relation("DrawCreatedBy")
  results       Result[]
  verifications WinnerVerification[]
  charity       Charity?             @relation("SelectedCharity", fields: [charityId], references: [id], onDelete: SetNull)

  @@index([charityId])
}

model Subscription {
  id                 String   @id @default(uuid())
  userId             String
  charityId          String?
  plan               String
  startDate          DateTime @default(now())
  endDate            DateTime
  isActive           Boolean  @default(true)
  contributionAmount Decimal  @default(0) @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity Charity? @relation("CharitySubscriptions", fields: [charityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([charityId])
}

model Score {
  id        String   @id @default(uuid())
  userId    String
  value     Int
  playedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  results Result[]

  @@index([userId, playedAt(sort: Desc)])
}

model Charity {
  id                     String   @id @default(uuid())
  name                   String
  description            String?
  image                  String?
  websiteUrl             String?
  contributionPercentage Int      @default(10)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  results       Result[]
  users         User[]         @relation("SelectedCharity")
  subscriptions Subscription[] @relation("CharitySubscriptions")
}

model Draw {
  id              String    @id @default(uuid())
  numbers         Int[]
  monthKey        String?   @unique
  isPublished     Boolean   @default(false)
  totalPool       Decimal   @default(0) @db.Decimal(12, 2)
  jackpotRollover Decimal   @default(0) @db.Decimal(12, 2)
  createdById     String
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy     User                 @relation("DrawCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  results       Result[]
  verifications WinnerVerification[]

  @@index([createdById])
}

model Result {
  id           String    @id @default(uuid())
  drawId       String
  userId       String
  charityId    String?
  scoreId      String?
  matchedCount Int       @default(0)
  matchTier    MatchTier @default(NO_WIN)
  isWinner     Boolean   @default(false)
  prizeAmount  Decimal   @default(0) @db.Decimal(12, 2)
  createdAt    DateTime  @default(now())

  draw         Draw                @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity      Charity?            @relation(fields: [charityId], references: [id], onDelete: SetNull)
  score        Score?              @relation(fields: [scoreId], references: [id], onDelete: SetNull)
  verification WinnerVerification?

  @@unique([drawId, userId])
  @@index([drawId])
  @@index([userId])
  @@index([charityId])
}

model WinnerVerification {
  id            String             @id @default(uuid())
  resultId      String             @unique
  drawId        String
  userId        String
  proofImage    String
  status        VerificationStatus @default(PENDING)
  paymentStatus PaymentStatus      @default(PENDING)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  result Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  draw   Draw   @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([drawId])
  @@index([userId])
}
